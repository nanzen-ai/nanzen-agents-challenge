# LLM provider configuration (any OpenAI-compatible API)
# -------------------------------------------------------

# Required: model identifier
MODEL_ID=accounts/fireworks/models/minimax-m2p5

# Optional: API key (not needed for local servers like llama.cpp or Ollama)
API_KEY=your-api-key-here

# Optional: base URL (omit to use OpenAI's default endpoint)
# Examples:
#   Fireworks AI    — https://api.fireworks.ai/inference/v1
#   Together AI     — https://api.together.xyz/v1
#   OpenRouter      — https://openrouter.ai/api/v1
#   Ollama          — http://localhost:11434/v1
#   llama.cpp       — http://localhost:8080/v1
API_BASE=https://api.fireworks.ai/inference/v1

# -------------------------------------------------------
# Local llama.cpp example (uncomment and adjust):
#
#   MODEL_ID=qwen3.5-35b
#   API_BASE=http://localhost:8080/v1
#   # API_KEY not needed
#
# Start llama-server first:
#   llama-server -m ~/.cache/huggingface/hub/.../model.gguf \
#     --port 8080 -ngl 99 -c 32768 --flash-attn
# -------------------------------------------------------
